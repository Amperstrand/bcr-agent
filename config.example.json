{
  "llm": {
    "provider": "opencode",
    "opencode_path": "opencode",
    "model": "zai/glm-4.6",
    "timeout_seconds": 300
  },
  "agent": {
    "max_diff_chars": 15000,
    "max_irc_chars": 8000,
    "max_github_chars": 4000,
    "previous_answers_context": 4
  },
  "cache": {
    "enabled": true,
    "data_dir": "data",
    "results_dir": "results"
  }
}
