# Data and results (generated at runtime)
data/*.json
data/*.txt
results/*.json
results/*.txt

# Keep example data
!data/.gitkeep
!results/.gitkeep

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
venv/
.venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Config (contains API keys)
config.json
# Keep the nsite deployment config — it holds relays/servers/profile only, no secrets.
!.nsite/config.json

# Logs
*.log

# OpenCode internal state
.omo/

# Environment / secrets (NEVER commit these)
.env
.env.*
*.env
secrets
secrets.*
*secret*
!secret_scanner.py
*credential*
*nsec*
*.nsec
config.local.json

# SSH / deploy keys
*_ed25519
*_ed25519.pub
*id_rsa
*id_rsa.pub

# Cashu wallet data
.cashu/
